# Copy to .env.local for local dev (optional — dev proxy in vite.config.js
# already points to the backend by default).

# Only needed if the backend runs somewhere other than localhost:4000:
VITE_BACKEND_URL=http://localhost:4000

# Only needed for production builds NOT served behind the same reverse proxy
# as the API (leave unset if frontend and backend share an origin):
# VITE_API_BASE_URL=https://api.example.com
